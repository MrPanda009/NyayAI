# Never needed - OS/environment specific
venv/
**/__pycache__/
**/*.pyc
**/*.pyo

# Secrets - go in Railway Variables instead
.env

# Local test output - generated at runtime, too large for image
output_docs/

# Empty runtime folder - created by the app on startup
uploads/

# Local SQLite test data - not persistent in Docker anyway
nyayai_cases.db

# Test files - not needed in production
tests/
